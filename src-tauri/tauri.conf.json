{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "轻启·服务管理器",
  "version": "0.1.0",
  "identifier": "com.makabaka.lite-service-manager",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "轻启·服务管理器",
        "width": 1160,
        "height": 780,
        "minWidth": 980,
        "minHeight": 640,
        "decorations": false,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis",
      "msi"
    ],
    "category": "DeveloperTool",
    "shortDescription": "轻量命令服务管理器",
    "longDescription": "一个基于 Tauri + React + Rust 的 Windows 轻量命令托管和服务管理器。",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  }
}
